# Copy to .env and fill in. Postgres values must match docker-compose.yml.
# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=fab
PG_USER=postgres
PG_PASSWORD=change-me

# External APIs (optional — only needed for pricing + the /scan endpoint)
JUSTTCG_API_KEY=
GOOGLE_VISION_KEY=
ANTHROPIC_API_KEY=
